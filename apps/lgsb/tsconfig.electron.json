{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "outDir": "./electron-dist",
    "rootDir": "./electron",
    "sourceMap": true,
    "declaration": true
  },
  "include": ["electron/**/*.ts"]
}
